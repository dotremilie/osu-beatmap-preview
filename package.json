{
  "name": "osu-beatmap-preview",
  "version": "0.1.4",
  "description": "Canvas renderer for osu!standard beatmap previews.",
  "license": "MIT",
  "author": "dotremilie",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dotremilie/osu-beatmap-preview.git"
  },
  "bugs": {
    "url": "https://github.com/dotremilie/osu-beatmap-preview/issues"
  },
  "homepage": "https://github.com/dotremilie/osu-beatmap-preview#readme",
  "type": "module",
  "sideEffects": false,
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./assets/*": "./assets/*"
  },
  "files": [
    "dist",
    "assets",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "node --input-type=module -e \"import { rmSync } from 'node:fs'; rmSync('dist', { recursive: true, force: true });\"",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.test.json --noEmit && tsc -p tsconfig.demo.json --noEmit",
    "test": "vitest run",
    "build": "npm run clean && vite build && tsc -p tsconfig.build.json",
    "demo": "vite --config vite.demo.config.ts",
    "demo:build": "vite build --config vite.demo.config.ts",
    "prepack": "npm run build"
  },
  "dependencies": {
    "osu-classes": "^3.1.0",
    "osu-parsers": "^4.1.7",
    "osu-standard-stable": "^5.0.1"
  },
  "devDependencies": {
    "typescript": "~7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
